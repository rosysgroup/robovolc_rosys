<?xml version="1.0"?>
<robot name="robovolc" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="$(find robovolc_rosys)/urdf/imu.urdf.xacro" />
  <xacro:include filename="$(find robovolc_rosys)/urdf/hokuyo.urdf.xacro" />
  <xacro:include filename="$(find robovolc_rosys)/urdf/d435_camera.urdf.xacro" />
  <xacro:include filename="$(find robovolc_rosys)/urdf/gps.urdf.xacro" />

  <xacro:arg name="enable_gazebo_plugin" default="true" />

  <xacro:arg name="sensors_pose_file" default="$(find robovolc_rosys)/config/sensors_pose.yaml" />
  <xacro:property name="sensors_pose_file" value="$(arg sensors_pose_file)" />
  <xacro:property name="camera_front"
    value="${xacro.load_yaml(sensors_pose_file)['camera_front']}" />
  <xacro:property name="camera_front_left"
    value="${xacro.load_yaml(sensors_pose_file)['camera_front_left']}" />
  <xacro:property name="camera_front_right"
    value="${xacro.load_yaml(sensors_pose_file)['camera_front_right']}" />
  <xacro:property name="camera_back" value="${xacro.load_yaml(sensors_pose_file)['camera_back']}" />
  <xacro:property name="imu" value="${xacro.load_yaml(sensors_pose_file)['imu']}" />
  <xacro:property name="lidar" value="${xacro.load_yaml(sensors_pose_file)['lidar']}" />
  <xacro:property name="gps" value="${xacro.load_yaml(sensors_pose_file)['gps']}" />

  <xacro:property name="degree30" value="0.52" />
  <xacro:property name="degree45" value="0.79" />
  <xacro:property name="degree60" value="1.05" />
  <xacro:property name="degree90" value="1.57" />
  <xacro:property name="degree180" value="3.14" />

  <xacro:property name="base_width" value="0.8" />
  <xacro:property name="base_length" value="1.4" />
  <xacro:property name="base_height" value="0.6" />
  <xacro:property name="mass" value="30.0" />
  <xacro:property name="frame" value="0.015" />

  <xacro:property name="wheel_radius" value="0.20" />
  <xacro:property name="wheel_width" value="0.30" />



  <!-- - - - - -  Define intertial property macros - - - - - -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}"
        iyz="0.0" izz="${(m/12) * (w*w + h*h)}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
      <mass value="${m}" />
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0" iyy="${(m/12) * (3*r*r + h*h)}"
        iyz="0" izz="${(m/2) * (r*r)}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}" />
      <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * m * (r*r)}" iyz="0.0"
        izz="${(2/5) * m * (r*r)}" />
    </inertial>
  </xacro:macro>


  <!-- - - - - - Robot Base - - - - - -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
      <material name="YellowMod">
        <color rgba="0.90 0.61 0.17 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
    </collision>

    <xacro:box_inertia m="${mass}" w="${base_width}" d="${base_length}" h="${base_height}" />
  </link>

  <xacro:if value="$(arg enable_gazebo_plugin)">
    <gazebo reference="base_link">
      <material>Gazebo/Orange</material>
    </gazebo>
  </xacro:if>


  <!-- - - - - - Wheels - - - - - -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}" />
        </geometry>
        <material name="Gray">
          <color rgba="0.5 0.5 0.5 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}" />
        </geometry>
      </collision>

      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}" />
    </link>

    <xacro:if value="$(arg enable_gazebo_plugin)">
      <gazebo reference="${prefix}_link">
        <mu1>1.5</mu1>
        <mu2>0.05</mu2>
        <fdir1>1 0 0</fdir1>
        <kp>1e6</kp>
        <kd>1.0</kd>
        <material>Gazebo/DarkGray</material>
      </gazebo>
    </xacro:if>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link" />
      <child link="${prefix}_link" />
      <origin xyz="${x_reflect * base_length/2} ${y_reflect * (base_width/2 + wheel_width/2)} ${-(base_height/2 - 0.10)}"
        rpy="0 0 0" />
      <axis xyz="0 1 0" />
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="front_left"  x_reflect="1"  y_reflect="1" />
  <xacro:wheel prefix="front_right" x_reflect="1"  y_reflect="-1" />
  <xacro:wheel prefix="rear_left"   x_reflect="-1" y_reflect="1" />
  <xacro:wheel prefix="rear_right"  x_reflect="-1" y_reflect="-1" />

  <!-- - - - - - Center Wheels (visual only) - - - - - -->
  <xacro:macro name="wheel_visual" params="prefix y_reflect">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}" />
        </geometry>
        <material name="Gray">
          <color rgba="0.5 0.5 0.5 1.0" />
        </material>
      </visual>
    </link>

    <xacro:if value="$(arg enable_gazebo_plugin)">
      <gazebo reference="${prefix}_link">
        <material>Gazebo/DarkGray</material>
      </gazebo>
    </xacro:if>

    <joint name="${prefix}_joint" type="fixed">
      <parent link="base_link" />
      <child link="${prefix}_link" />
      <origin xyz="0 ${y_reflect * (base_width/2 + wheel_width/2)} ${-(base_height/2 - 0.10)}"
        rpy="0 0 0" />
    </joint>
  </xacro:macro>

  <xacro:wheel_visual prefix="center_left"  y_reflect="1" />
  <xacro:wheel_visual prefix="center_right" y_reflect="-1" />


  <!-- - - - - - Gazebo Plugin - - - - - -->
  <xacro:if value="$(arg enable_gazebo_plugin)">
    <gazebo>
      <plugin name='skid_steer_drive' filename='libgazebo_ros_diff_drive.so'>

        <num_wheel_pairs>2</num_wheel_pairs>

        <!-- front pair -->
        <left_joint>front_left_joint</left_joint>
        <right_joint>front_right_joint</right_joint>
        <!-- rear pair -->
        <left_joint>rear_left_joint</left_joint>
        <right_joint>rear_right_joint</right_joint>

        <!-- kinematics (repeated once per pair) -->
        <wheel_separation>${base_width + wheel_width}</wheel_separation>
        <wheel_separation>${base_width + wheel_width}</wheel_separation>
        <wheel_diameter>${wheel_radius * 2}</wheel_diameter>
        <wheel_diameter>${wheel_radius * 2}</wheel_diameter>

        <!-- limits -->
        <max_wheel_torque>200</max_wheel_torque>
        <max_wheel_acceleration>5.0</max_wheel_acceleration>

        <!-- output -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>false</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>

        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
      </plugin>
    </gazebo>
  </xacro:if>

  <!-- - - - - - Imu link and plugin - - - - - -->
  <xacro:imu_sensor xyz="${imu['xoff']} ${imu['yoff']} ${imu['zoff']}"
    rpy="${imu['roll']} ${imu['pitch']} ${imu['yaw']}"
    color="${imu['color']}"
    parent="base_link">
  </xacro:imu_sensor>

  <!-- - - - - - Laser link and plugin - - - - - -->
  <xacro:hokuyo_laser xyz="${lidar['xoff']} ${lidar['yoff']} ${lidar['zoff']}"
    rpy="${lidar['roll']} ${lidar['pitch']} ${lidar['yaw']}"
    parent="base_link">
  </xacro:hokuyo_laser>

  <!-- - - - - - GPS link and plugin - - - - - -->
  <xacro:gps_sensor xyz="${gps['xoff']} ${gps['yoff']} ${gps['zoff']}"
    rpy="${gps['roll']} ${gps['pitch']} ${gps['yaw']}"
    color="${gps['color']}"
    parent="base_link">
  </xacro:gps_sensor>

  <!-- - - - - - Camera Front - - - - - -->
  <xacro:d435_camera xyz="${camera_front['xoff']} ${camera_front['yoff']} ${camera_front['zoff']}"
                rpy="${camera_front['roll']} ${camera_front['pitch']} ${camera_front['yaw']}"
                color="${camera_front['color']}"
                parent="base_link"
                camera_name="camera_front">
  </xacro:d435_camera>

  <!-- - - - - - Stereo Camera Front Left - - - - - -->
  <!-- <xacro:d435_camera xyz="${camera_front_left['xoff']} ${camera_front_left['yoff']}
  ${camera_front_left['zoff']}"
                rpy="${camera_front_left['roll']} ${camera_front_left['pitch']} ${camera_front_left['yaw']}"
                color="${camera_front_left['color']}"
                parent="base_link"
                camera_name="stereo_camera_front_left">
  </xacro:d435_camera>  -->

  <!-- - - - - - Stereo Camera Front Right - - - - - -->
  <!-- <xacro:d435_camera xyz="${camera_front_right['xoff']} ${camera_front_right['yoff']}
  ${camera_front_right['zoff']}"
                rpy="${camera_front_right['roll']} ${camera_front_right['pitch']} ${camera_front_right['yaw']}"
                color="${camera_front_right['color']}"
                parent="base_link"
                camera_name="stereo_camera_front_right">
  </xacro:d435_camera>  -->

  <!-- - - - - - Stereo Camera Back - - - - - -->
  <!-- <xacro:d435_camera xyz="${camera_back['xoff']} ${camera_back['yoff']} ${camera_back['zoff']}"
                rpy="${camera_back['roll']} ${camera_back['pitch']} ${camera_back['yaw']}"
                color="${camera_back['color']}"
                parent="base_link"
                camera_name="stereo_camera_back">
  </xacro:d435_camera>  -->


</robot>